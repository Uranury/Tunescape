                    "application/json"
                ],
                "tags": [
                    "leaderboards"
                ],
                "summary": "Get global leaderboard",
                "parameters": [
                    {
                        "enum": [
                            "valence",
                            "energy",
                            "danceability",
                            "acousticness"
                        ],
                        "type": "string",
                        "description": "Audio feature",
                        "name": "feature",
                        "in": "path",
                        "required": true
                    },
                    {
                        "type": "integer",
                        "description": "Number of entries to return (default 10)",
                        "name": "limit",
                        "in": "query"
                    },
                    {
                        "type": "integer",
                        "description": "Number of entries to skip (default 0)",
                        "name": "offset",
